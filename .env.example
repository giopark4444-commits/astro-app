# Aluna — plantilla de variables de entorno. Copiar a .env.local y rellenar.
# .env.local está gitignored; este .env.example sí se versiona (sin valores reales).

# Supabase (proyecto "aluna"). URL y llave pública/anon son seguras para cliente.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<legacy-anon-jwt>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>

# SECRETO — solo backend (servicio de cómputo). Nunca en cliente ni en git.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>
