# Aluna web — públicas (seguras para el navegador). Copiar a .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<legacy-anon-jwt-o-publishable>
# Origen de esta app — arma el return_url del checkout de Dodo. En dev, el
# puerto de este proyecto; Gio la actualiza al dominio real en producción.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --- Lecturas IA (Profunda/Completa) — SECRETO, solo servidor. Sin ninguna de
# estas llaves, los niveles largos muestran la "Esencia" escrita a mano.
# Proveedor intercambiable: pon la llave del que quieras usar. READING_PROVIDER
# es opcional; sin él, usa el primero con llave en orden anthropic > openai > gemini.
# READING_PROVIDER=anthropic
ANTHROPIC_API_KEY=<sk-ant-...>
# OPENAI_API_KEY=<sk-...>
# GEMINI_API_KEY=<...>
# Modelo por proveedor (opcional; ajusta al modelo vigente que prefieras):
# ANTHROPIC_READING_MODEL=claude-opus-4-8
# OPENAI_READING_MODEL=gpt-4o
# GEMINI_READING_MODEL=gemini-1.5-pro
# Voz local gratis (Ollama), sin llave — solo participa si la enciendes:
# OLLAMA_ENABLED=1
# OLLAMA_READING_MODEL=hermes3:8b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Hermes vía Nous Portal y DeepSeek (los soporta lib/reading/provider.ts):
# NOUS_API_KEY=<...>            # NOUS_MODEL=Hermes-4-70B
# DEEPSEEK_API_KEY=<...>        # DEEPSEEK_READING_MODEL=deepseek-chat
# Free tiers (Groq/OpenRouter): SOLO vía el picker de pruebas, nunca fallback
# de producción (sus límites gratis degradarían a usuarios reales):
# GROQ_API_KEY=<gsk_...>        # GROQ_READING_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=<sk-or-...> # OPENROUTER_READING_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Visión (lectura de mano): modelo que MIRA la foto (gemini/openai/anthropic).
# GEMINI_VISION_MODEL=gemini-3.5-flash   # ANTHROPIC_VISION_MODEL=claude-sonnet-5
# Selector de modelos de PRUEBA en los chats (banco A/B): siempre encendido en
# `pnpm dev`; en un deploy solo si activas el flag. Ver lib/reading/model-catalog.ts.
# MODEL_PICKER_ENABLED=1

# --- Cobro (Dodo Payments) — SECRETO, solo servidor. Llave de API + un
# producto por plan, creados en su dashboard. Sin DODO_PAYMENTS_API_KEY,
# getDodoClient() lanza recién al usarse (no rompe el build ni el import).
DODO_PAYMENTS_API_KEY=<dodo-api-key>
# Secreto del webhook (Standard Webhooks, prefijo whsec_) — sin esto,
# app/api/webhooks/dodo/route.ts responde 500 not_configured a cualquier evento.
DODO_PAYMENTS_WEBHOOK_SECRET=<whsec_...>
DODO_PRODUCT_MONTHLY=<pdt_...>
DODO_PRODUCT_YEARLY=<pdt_...>
# Los 3 packs de créditos comprables una sola vez (Task 7, ver lib/credits/
# config.ts): sin el env de un pack, ese pack concreto no se puede comprar
# (checkout responde 500 pack_not_configured) ni acreditar por webhook.
DODO_PRODUCT_CREDITS_100=<pdt_...>
DODO_PRODUCT_CREDITS_300=<pdt_...>
DODO_PRODUCT_CREDITS_1000=<pdt_...>

# --- Créditos y acceso Plus (lib/credits/config.ts, lib/plan-gate.ts) —
# TODAS opcionales, cada una cae a su default sensato sin configurar nada.
# Interruptor único: app entera ABIERTA (sin candados Plus) mientras se
# decide cómo organizar los planes; "0" restaura los candados.
# ALUNA_ALL_ACCESS=0
# Modelo usado por el chat/lecturas premium (Claude explícito, no el mismo
# que el fallback gratis) — por defecto "claude-sonnet-5".
# ALUNA_PREMIUM_MODEL=claude-sonnet-5
# Costo en créditos de un turno de chat premium (por encima del tope gratis diario). Default 1.
# ALUNA_CREDIT_COST_CHAT=1
# Costo en créditos de una lectura premium (carta/tarot con proveedor real). Default 3.
# ALUNA_CREDIT_COST_READING=3
# Créditos que otorga el refill mensual del plan Plus (uno por período de suscripción). Default 60.
# ALUNA_PLUS_MONTHLY_CREDITS=60
# Tope diario de turnos de chat gratis (sin plan, sin gastar créditos). Default 5.
# ALUNA_FREE_DAILY_CHAT_CAP=5
